{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "*.egg-info/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["htmlcov/**", ".coverage"],
      "inputs": ["src/**", "tests/**", "pyproject.toml"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
